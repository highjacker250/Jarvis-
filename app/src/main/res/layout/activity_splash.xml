<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/jarvis_bg">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_splash"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:lottie_rawRes="@raw/ai_orb"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"/>

    <TextView
        android:id="@+id/tv_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="JARVIS AI"
        android:textColor="@color/jarvis_cyan"
        android:textSize="36sp"
        android:letterSpacing="0.2"
        android:textStyle="bold"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tv_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aapka Personal AI Assistant"
        android:textColor="@color/jarvis_white_60"
        android:textSize="16sp"
        android:layout_marginTop="8dp"/>

</LinearLayout>
