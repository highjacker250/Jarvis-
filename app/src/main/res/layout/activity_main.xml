encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050A1A">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:text="JARVIS AI"
            android:textColor="#00D4FF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <ImageButton
            android:id="@+id/btn_history"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_history"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#00D4FF"/>

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#00D4FF"/>
    </LinearLayout>

    <!-- AI Orb Animation (Lottie) -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_orb"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:lottie_rawRes="@raw/ai_orb"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_response"
        android:layout_marginTop="20dp"/>

    <!-- Response Text -->
    <TextView
        android:id="@+id/tv_response"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hello! I am Jarvis. Tap the mic or say 'Hey Jarvis'"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="24dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        app:layout_constraintBottom_toTopOf="@id/tv_transcript"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Transcript -->
    <TextView
        android:id="@+id/tv_transcript"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap mic to speak"
        android:textColor="#80FFFFFF"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@id/btn_mic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Mic Button -->
    <ImageButton
        android:id="@+id/btn_mic"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_mic"
        android:background="@drawable/mic_button_bg"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>