<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.JarvisAI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/jarvis_cyan</item>
        <item name="colorPrimaryVariant">@color/jarvis_cyan_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/jarvis_cyan</item>
        <item name="android:windowBackground">@color/jarvis_bg</item>
        <item name="android:statusBarColor">@color/jarvis_bg</item>
        <item name="android:navigationBarColor">@color/jarvis_bg</item>
    </style>

    <style name="Theme.JarvisAI.Splash" parent="Theme.JarvisAI">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.JarvisAI.ActionBar" parent="Theme.JarvisAI">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
        <item name="colorPrimary">@color/jarvis_bg</item>
        <item name="colorPrimaryVariant">@color/jarvis_bg</item>
        <item name="actionBarStyle">@style/JarvisActionBar</item>
    </style>

    <style name="JarvisActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/jarvis_bg</item>
        <item name="titleTextStyle">@style/JarvisActionBarTitle</item>
    </style>

    <style name="JarvisActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/jarvis_cyan</item>
    </style>
</resources>
